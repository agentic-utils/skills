{
  "name": "agentic-utils",
  "owner": {
    "name": "agentic-utils"
  },
  "plugins": [
    {
      "name": "ty-lsp",
      "description": "Python language server (ty) for Claude Code",
      "version": "1.0.0",
      "source": "./plugins/ty-lsp",
      "category": "development",
      "lspServers": {
        "ty": {
          "command": "uvx",
          "args": ["ty@latest", "server"],
          "extensionToLanguage": {
            ".py": "python",
            ".pyi": "python"
          }
        }
      }
    },
    {
      "name": "svelte-lsp",
      "description": "Svelte language server for Claude Code",
      "version": "1.0.0",
      "source": "./plugins/svelte-lsp",
      "category": "development",
      "lspServers": {
        "svelte": {
          "command": "npx",
          "args": ["svelte-language-server", "--stdio"],
          "extensionToLanguage": {
            ".svelte": "svelte"
          }
        }
      }
    },
    {
      "name": "disk-cleanup",
      "description": "Scan for and clean up disk space on macOS",
      "version": "1.0.0",
      "source": "./plugins/disk-cleanup",
      "category": "utilities"
    },
    {
      "name": "claude-code",
      "description": "Skills grounded in Claude Code internals",
      "version": "1.0.1",
      "source": "./plugins/claude-code",
      "category": "utilities"
    }
  ]
}
